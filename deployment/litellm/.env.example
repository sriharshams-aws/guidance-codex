# AWS credentials — on ECS, prefer the task role and leave the key fields blank.
# For local docker-compose, set static keys or a short-lived session if needed.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_TOKEN_REFRESH_INTERVAL_SECONDS=300

# Optional override if your upstream Bedrock region differs from AWS_REGION.
# BEDROCK_MANTLE_REGION=us-east-1

# LiteLLM master key — used by admins to manage the gateway (rotate regularly)
LITELLM_MASTER_KEY=sk-change-me

# SSO — Generic OIDC provider (Cognito, Okta, Azure AD, Auth0, etc.)
# Cognito example (replace POOL_ID, CLIENT_ID, DOMAIN, REGION):
#   GENERIC_CLIENT_ID=<cognito-app-client-id>
#   GENERIC_CLIENT_SECRET=none                          # Cognito public client has no secret
#   GENERIC_AUTHORIZATION_ENDPOINT=https://<domain>.auth.<region>.amazoncognito.com/oauth2/authorize
#   GENERIC_TOKEN_ENDPOINT=https://<domain>.auth.<region>.amazoncognito.com/oauth2/token
#   GENERIC_USERINFO_ENDPOINT=https://<domain>.auth.<region>.amazoncognito.com/oauth2/userInfo
#   GENERIC_REDIRECT_URI=http://localhost:4000/sso/callback
#
# Okta example:
#   GENERIC_AUTHORIZATION_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/authorize
#   GENERIC_TOKEN_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/token
#   GENERIC_USERINFO_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/userinfo
PROXY_BASE_URL=http://localhost:4000
GENERIC_CLIENT_ID=
GENERIC_CLIENT_SECRET=none
GENERIC_AUTHORIZATION_ENDPOINT=
GENERIC_TOKEN_ENDPOINT=
GENERIC_USERINFO_ENDPOINT=
GENERIC_REDIRECT_URI=http://localhost:4000/sso/callback

# OpenTelemetry — set to your OTel collector endpoint.
# OTEL_EXPORTER=otlp_http uses the collector's HTTP port (4318), matching
# docker-compose.yml. Port 4317 is the gRPC receiver; use it only with a
# gRPC exporter.
OTEL_EXPORTER=otlp_http
OTEL_ENDPOINT=http://otel-collector:4318
# OTEL_HEADERS=key=value   # optional, for authenticated collectors

# LiteLLM database (required for spend tracking and virtual keys)
DATABASE_URL=postgresql://litellm:litellm@db:5432/litellm
